# Cascade Engine Environment Variables

# API Keys for cloud tiers
CASCADE_MID_API_KEY=sk-your-openai-key-here
CASCADE_PREMIUM_API_KEY=sk-your-openai-key-here

# Local engine
CASCADE_LOCAL_URL=http://localhost:11434
CASCADE_LOCAL_MODEL=llama3.2:3b

# Gateway
API_KEYS=dev-key-123,prod-key-456
GATEWAY_PORT=3000

# Router tuning
CASCADE_MAX_COST=0.05
